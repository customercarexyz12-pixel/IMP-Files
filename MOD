const express = require("express");
const fs = require("fs");
const app = express();

app.use(express.urlencoded({ extended: true }));

// Show HTML Form
app.get("/", (req, res) => {
    res.send(`
        <h2>Append File Content</h2>
        <form method="POST" action="/append">
            First File Name: <input type="text" name="file1"><br><br>
            Second File Name: <input type="text" name="file2"><br><br>
            <button type="submit">Append</button>
        </form>
    `);
});

// Append File Content
app.post("/append", (req, res) => {
    const file1 = req.body.file1;
    const file2 = req.body.file2;

    fs.readFile(file1, "utf8", (err, data) => {
        if (err) return res.send("Error reading first file");

        fs.appendFile(file2, data, (err) => {
            if (err) return res.send("Error appending to second file");

            res.send("Content appended successfully!");
        });
    });
});

app.listen(3000, () => {
    console.log("Server running at http://localhost:3000");
});

