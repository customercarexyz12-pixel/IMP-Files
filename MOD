import android.text.style.UnderlineSpan;

public class MainActivity extends AppCompatActivity {

    protected void onCreate(Bundle b) {
        super.onCreate(b);
        setContentView(R.layout.activity_main);

        EditText name = findViewById(R.id.etName);
        TextView msg = findViewById(R.id.txtMsg);

        RadioButton red = findViewById(R.id.red);
        RadioButton blue = findViewById(R.id.blue);
        RadioButton green = findViewById(R.id.green);

        CheckBox bold = findViewById(R.id.bold);
        CheckBox italic = findViewById(R.id.italic);
        CheckBox underline = findViewById(R.id.underline);

        Button show = findViewById(R.id.btnShow);
        Button clear = findViewById(R.id.btnClear);
        Button exit = findViewById(R.id.btnExit);

        show.setOnClickListener(v -> {

            String text = "Hello " + name.getText().toString();
            msg.setText(text);

            // Color
            if(red.isChecked()) msg.setTextColor(Color.RED);
            if(blue.isChecked()) msg.setTextColor(Color.BLUE);
            if(green.isChecked()) msg.setTextColor(Color.GREEN);

            // Style
            int style = Typeface.NORMAL;
            if(bold.isChecked()) style |= Typeface.BOLD;
            if(italic.isChecked()) style |= Typeface.ITALIC;
            msg.setTypeface(null, style);

            // Underline
            if(underline.isChecked()){
                SpannableString s = new SpannableString(text);
                s.setSpan(new UnderlineSpan(),0,s.length(),0);
                msg.setText(s);
            }
        });

        clear.setOnClickListener(v -> {
            name.setText("");
            msg.setText("");
        });

        exit.setOnClickListener(v -> finish());
    }
}







