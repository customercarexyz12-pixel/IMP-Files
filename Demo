int n,visited[50],q=-1,adj[10][10],stack[10],top=-1,fstack[10],ftop=-1; 
void dfs(int v);  
int vcheck(int v);  
void revstack();  
void printstack(); 
int main() 
{ 
int i,j,v; 
printf("\nEnter number of vertices=>");  
scanf("%d",&n); 
printf("\nEnter adjancy matrix=>");  
for(i=1;i<=n;i++) 
for(j=1;j<=n;j++)  
scanf("%d",&adj[i][j]); 
printf("\nToplogical Sort=>");  
for(i=1;i<=n;i++) 
{ 
dfs(i);  
revstack(); 
} 
printstack();  
return 0; 
} 
void dfs(int v) 
{ 
int i;  
if(vcheck(v)==0) 
{ 
top++;  
stack[top]=v;  
q++; 
visited[q]=v;  
for(i=1;i<=n;i++)  
if(adj[v][i]==1)  
dfs(i); 
} 
} 
int vcheck(int ele) 
{ 
int i; 
for(i=0;i<=q;i++) 
{ 
if(ele==visited[i]) 
return 1; 
} 
return 0; 
} 
void revstack() 
{ 
while(top>=0) 
{ 
ftop++;  
fstack[ftop]=stack[top];  
top--; 
} 
} 
void printstack() 
{ 
while(ftop>=0) 
{ 
printf("%d\t",fstack[ftop]); 
ftop--; 
} 
} 

Q.2) Write a program to solve N Queens Problem using Backtracking.
#include<stdio.h>
#include<stdlib.h>
int x[10], n;
int place(int k,int i)
{
    for(int j=1;j<k;j++)
        if(x[j]==i || abs(x[j]-i)==abs(j-k))
            return 0;
    return 1;
}
void queen(int k)
{
    for(int i=1;i<=n;i++)
    {
        if(place(k,i)){
            x[k]=i;
            if(k==n){
                for(int j=1;j<=n;j++)
                    printf("%d ",x[j]);
                printf("\n");
            }
            else
                queen(k+1);
        }
    }
}
int main()
{
    printf("Enter N: ");
    scanf("%d",&n);	
    queen(1);
    return 0;
}
